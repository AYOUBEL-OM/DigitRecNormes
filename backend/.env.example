# Copier vers backend/.env et renseigner les valeurs (ne jamais committer .env).

# --- Base de données (au moins l’un des deux blocs) ---
# Recommandé : URL complète depuis le dashboard Supabase (Settings → Database)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Sinon : hôte + mot de passe (construit une URL dans l’app)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres
POSTGRES_SSL_MODE=require

# --- Supabase (client / stockage si utilisé côté backend) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_KEY=

# --- JWT ---
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- IA / transcription entretien oral (Groq Whisper uniquement) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# --- App ---
DEBUG=false
APP_NAME=DigitRec
FRONTEND_PUBLIC_URL=http://localhost:8080

UPLOAD_DIR=uploads/cv
ORAL_RECORDINGS_DIR=uploads/oral_recordings
ORAL_ANSWERS_DIR=uploads/oral_answers
ORAL_SNAPSHOTS_DIR=uploads/oral_snapshots
MAX_CV_SIZE_MB=5
ALLOWED_CV_EXTENSIONS=pdf,doc,docx

# --- SMTP (e-mails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Stripe (Checkout : packs payants uniquement ; l’essai gratuit ne passe pas par Stripe) ---
# En local : Dashboard Stripe (mode TEST) → clés API → Secret key sk_test_…
STRIPE_SECRET_KEY=
# Optionnel côté front (Elements) ; le Checkout hébergé fonctionne avec la seule clé secrète backend.
STRIPE_PUBLISHABLE_KEY=
# Webhook : uniquement pour POST /api/subscriptions/webhook (sinon laisser vide en dev).
STRIPE_WEBHOOK_SECRET=
# Price IDs récurrents (mode TEST : créer un prix « recurring » sur un produit, copier price_…).
# Alias acceptés : STRIPE_PRICE_ID_PACK_LIMITE / STRIPE_PRICE_ID_PACK_ILLIMITE
STRIPE_PRICE_ID_LIMITED=
STRIPE_PRICE_ID_UNLIMITED=

